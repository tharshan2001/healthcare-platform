# AI Symptom Service Environment Variables
# Copy this file to .env and update the values

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# PostgreSQL connection URL
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@ai_symptom_db:5432/ai_symptom_db

# ===========================================
# REDIS CONFIGURATION
# ===========================================
# Redis connection URL for caching
REDIS_URL=redis://redis:6379/0

# Cache TTL in seconds (default: 1 hour)
REDIS_CACHE_TTL=3600

# ===========================================
# OPENAI CONFIGURATION
# ===========================================
# Your OpenAI API key (required for AI analysis)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# OpenAI model to use for analysis
# Options: gpt-4-turbo-preview, gpt-4, gpt-3.5-turbo
OPENAI_MODEL=gpt-4-turbo-preview

# Maximum tokens for AI response
OPENAI_MAX_TOKENS=2000

# Temperature for AI responses (0.0-1.0, lower = more focused)
OPENAI_TEMPERATURE=0.3

# ===========================================
# APPLICATION SETTINGS
# ===========================================
# Application name
APP_NAME=AI Symptom Service

# Application version
APP_VERSION=1.0.0

# Debug mode (set to false in production)
DEBUG=true

# Secret key for security (change in production!)
SECRET_KEY=your-super-secret-key-change-in-production

# ===========================================
# API SETTINGS
# ===========================================
# API version prefix
API_V1_PREFIX=/api/v1

# Rate limiting (requests per minute)
RATE_LIMIT_PER_MINUTE=30

# ===========================================
# CORS SETTINGS
# ===========================================
# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ===========================================
# EMERGENCY DETECTION
# ===========================================
# Keywords that trigger emergency detection (comma-separated, lowercase)
EMERGENCY_KEYWORDS=chest pain,difficulty breathing,severe bleeding,unconscious,stroke,heart attack,seizure,severe allergic reaction,anaphylaxis,suicidal,overdose
