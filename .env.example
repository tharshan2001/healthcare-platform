# Database Configuration (each service should have its own database)
DATABASE_URL=postgresql://user:password@localhost:5432/db_name
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Service URLs (for inter-service communication)
PATIENT_SERVICE_URL=http://localhost:8001
DOCTOR_SERVICE_URL=http://localhost:8002
APPOINTMENT_SERVICE_URL=http://localhost:8003
TELEMEDICINE_SERVICE_URL=http://localhost:8004
PAYMENT_SERVICE_URL=http://localhost:8005
NOTIFICATION_SERVICE_URL=http://localhost:8006
AI_SYMPTOM_SERVICE_URL=http://localhost:8007

# Stripe Configuration (replace with your actual keys)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# Google AI Configuration
GOOGLE_API_KEY=your_google_api_key_here

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Email Configuration
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password